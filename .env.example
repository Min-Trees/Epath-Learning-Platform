# ============================================================================
# Template cho Environment Variables — Dùng làm ví dụ
# Copy file này thành .env.local và điền giá trị thật
# ============================================================================

# ----------------------------------------------------------------------------
# Nhóm 1: Firebase Client (NEXT_PUBLIC_*) — Build-time + Client-side
# ----------------------------------------------------------------------------

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ----------------------------------------------------------------------------
# Nhóm 2: App Metadata (NEXT_PUBLIC_*)
# ----------------------------------------------------------------------------

NEXT_PUBLIC_APP_NAME=Epath System Training
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ----------------------------------------------------------------------------
# Nhóm 3: Firebase Admin SDK — Server-side ONLY
# ----------------------------------------------------------------------------

FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ----------------------------------------------------------------------------
# Nhóm 4: Viettel IDC S3 Storage — Server-side (S3-compatible)
# Endpoint mặc định: https://<your-endpoint>.vcos3.cloudstorage.com.vn
# Nếu chưa cấu hình Viettel IDC, set S3_USE_LOCAL_FALLBACK=1 để dùng local mock
# (chỉ dùng cho DEV, file sẽ được lưu trong thư mục LOCAL_S3_DIR).
# ----------------------------------------------------------------------------

S3_ENDPOINT=https://your-endpoint.vcos3.cloudstorage.com.vn
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your-bucket-name
S3_REGION=ap-southeast-1
# Khi =1, presigned URL trỏ về /api/uploads/local-receive (mock) thay vì Viettel IDC S3
S3_USE_LOCAL_FALLBACK=0

# ----------------------------------------------------------------------------
# Nhóm 5: Streaming Session Secret — Server-side
# ----------------------------------------------------------------------------

STREAM_SESSION_SECRET=generate-a-random-secret-here
